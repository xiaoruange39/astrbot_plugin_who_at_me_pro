{
    "global":  {
                   "description":  "全局使用配置",
                   "type":  "object",
                   "items":  {
                                 "enabled_group_umos":  {
                                                            "description":  "允许使用插件的群 UMO 白名单",
                                                            "type":  "list",
                                                            "default":  [

                                                                        ],
                                                            "hint":  "留空则所有群都可使用本插件；填入后只有这些 UMO 的群会记录、查询、清理和触发提醒。非白名单入口会静默忽略插件命令并阻止 LLM 接管。"
                                                        }
                             }
               },
    "record":  {
                   "description":  "记录查询配置",
                   "type":  "object",
                   "items":  {
                                 "max_records_per_target":  {
                                                                "description":  "每个群成员最多保留的艾特记录数",
                                                                "type":  "int",
                                                                "default":  300,
                                                                "hint":  "超过后会保留最新记录。"
                                                            },
                                 "recent_image_cache_records":  {
                                                                    "description":  "最近多少条记录缓存消息图片",
                                                                    "type":  "int",
                                                                    "default":  0,
                                                                    "hint":  "0 表示不缓存消息图片；大于 0 时仅最近 N 条记录保存本地图片缓存，旧记录会删除本地缓存并继续使用 QQ 临时链接。"
                                                                },
                                 "image_cache_retention_hours":  {
                                                                     "description":  "图片缓存保留时间(小时)",
                                                                     "type":  "int",
                                                                     "default":  24,
                                                                     "hint":  "定时清理该时间之前的旧图片缓存文件夹。如果设置为 0 或更低则禁用定时清理。"
                                                                 },
                                 "max_messages_per_image":  {
                                                                "description":  "单张查询图最多展示的消息条数",
                                                                "type":  "int",
                                                                "default":  12,
                                                                "hint":  "记录较多时会自动分多张图。"
                                                            },
                                 "max_query_pages":  {
                                                         "description":  "单次查询最多发送图片页数",
                                                         "type":  "int",
                                                         "default":  0,
                                                         "hint":  "0 表示不限制；大于 0 时只发送最新 N 页，再按排序方式展示。"
                                                     },
                                 "query_context_max_messages":  {
                                                                    "description":  "查询上下文最多缓存消息条数",
                                                                    "type":  "int",
                                                                    "default":  5,
                                                                    "hint":  "原版默认前后各 5 条。"
                                                                },
                                 "query_sort_order":  {
                                                          "description":  "查询结果排序方式",
                                                          "type":  "string",
                                                          "default":  "正序",
                                                          "options":  [
                                                                          "正序",
                                                                          "倒序"
                                                                      ],
                                                          "hint":  "正序=旧消息在上、最新消息在下；倒序=最新消息在上。"
                                                      }
                             }
               },
    "reminder":  {
                     "description":  "艾特提醒配置",
                     "type":  "object",
                     "items":  {
                                   "default_group_enabled":  {
                                                                 "description":  "新群默认开启被动艾特提醒",
                                                                 "type":  "bool",
                                                                 "default":  true,
                                                                 "hint":  "关闭后不会生成回群提醒；仍可用 #开启本群艾特提醒 单独开启。"
                                                             },
                                   "enabled_group_umos":  {
                                                              "description":  "限定开启提醒的群 UMO 名单",
                                                              "type":  "list",
                                                              "default":  [

                                                                          ],
                                                              "hint":  "留空则不限制群，继续使用默认群开关和群命令；填入后只有这些 UMO 的群会生成/推送提醒。可用 #艾特提醒状态 查看当前群 UMO。"
                                                          },
                                   "default_user_enabled":  {
                                                                "description":  "用户默认接收艾特提醒",
                                                                "type":  "bool",
                                                                "default":  true,
                                                                "hint":  "用户可用 #关闭我的艾特提醒 关闭。"
                                                            },
                                   "user_whitelist":  {
                                                          "description":  "允许接收提醒的用户 QQ 白名单",
                                                          "type":  "list",
                                                          "default":  [

                                                                      ],
                                                          "hint":  "留空则不限制用户；填入后只有这些 QQ 号会进入被动艾特提醒队列。只影响提醒，不影响手动查询。"
                                                      },
                                   "user_blacklist":  {
                                                          "description":  "禁止接收提醒的用户 QQ 黑名单",
                                                          "type":  "list",
                                                          "default":  [

                                                                      ],
                                                          "hint":  "填入后这些 QQ 号不会进入被动艾特提醒队列，也不会收到已排队的提醒。黑名单优先于白名单。只影响提醒，不影响手动查询。"
                                                      },
                                   "away_minutes":  {
                                                        "description":  "离开判定分钟数",
                                                        "type":  "int",
                                                        "default":  10,
                                                        "hint":  "用户回来发言时，艾特消息超过这个时间才可能触发提醒。"
                                                    },
                                   "min_messages_after_mention":  {
                                                                      "description":  "触发提醒所需的最少群消息数",
                                                                      "type":  "int",
                                                                      "default":  5,
                                                                      "hint":  "统计艾特消息之后、用户回来消息之前的群消息；与离开分钟数同时满足才提醒，0 表示不限制消息数。"
                                                                  },
                                   "max_pending_reminders":  {
                                                                 "description":  "每人每群最多保留的待提醒记录数",
                                                                 "type":  "int",
                                                                 "default":  50,
                                                                 "hint":  "超过后保留最新记录。"
                                                             },
                                   "max_reminder_pages":  {
                                                              "description":  "单次提醒最多发送图片页数",
                                                              "type":  "int",
                                                              "default":  0,
                                                              "hint":  "0 表示不限制；大于 0 时只发送前 N 页。"
                                                          },
                                   "default_context_enabled":  {
                                                                   "description":  "默认开启提醒截图上下文",
                                                                   "type":  "bool",
                                                                   "default":  false,
                                                                   "hint":  "开启后提醒截图可展示艾特前后消息。"
                                                               },
                                   "default_context_before":  {
                                                                  "description":  "默认提醒截图前文条数",
                                                                  "type":  "int",
                                                                  "default":  1
                                                              },
                                   "default_context_after":  {
                                                                 "description":  "默认提醒截图后文条数",
                                                                 "type":  "int",
                                                                 "default":  1
                                                             },
                                   "max_context_messages":  {
                                                                "description":  "提醒上下文最大条数",
                                                                "type":  "int",
                                                                "default":  5,
                                                                "hint":  "Web 配置和群命令设置都会受这个上限限制。"
                                                            }
                               }
                 },
    "render":  {
                   "description":  "图片渲染配置",
                   "type":  "object",
                   "items":  {
                                 "prefer_browser":  {
                                                        "description":  "优先使用 Playwright/Chromium 浏览器渲染",
                                                        "type":  "bool",
                                                        "default":  true
                                                    },
                                 "image_quality":  {
                                                       "description":  "JPEG 图片质量",
                                                       "type":  "int",
                                                       "default":  92,
                                                       "hint":  "范围建议 60-100。"
                                                   },
                                 "browser_timeout_seconds":  {
                                                                 "description":  "单次渲染总超时秒数",
                                                                 "type":  "int",
                                                                 "default":  25
                                                             },
                                 "page_timeout_ms":  {
                                                         "description":  "浏览器页面加载超时毫秒数",
                                                         "type":  "int",
                                                         "default":  20000
                                                     },
                                 "header_image_url":  {
                                                          "description":  "结果图顶部状态栏图片 URL / 本地路径",
                                                          "type":  "string",
                                                          "default":  "",
                                                          "hint":  "可选项。留空时使用插件内置本地图片；Page 上传的自定义图片优先级更高。"
                                                      },
                                 "footer_image_url":  {
                                                          "description":  "结果图底部图片 URL / 本地路径",
                                                          "type":  "string",
                                                          "default":  "",
                                                          "hint":  "可选项。留空时使用插件内置本地图片；Page 上传的自定义图片优先级更高。"
                                                      },
                                 "cleanup_render_hours":  {
                                                              "description":  "渲染临时图片保留小时数",
                                                              "type":  "int",
                                                              "default":  24
                                                          }
                             }
               },
    "message":  {
                    "description":  "提示文案配置",
                    "type":  "object",
                    "items":  {
                                  "waiting_text_template":  {
                                                                "description":  "查询等待提示模板",
                                                                "type":  "string",
                                                                "default":  "让{bot_name}看看谁艾特过你哦，稍等一下~",
                                                                "hint":  "可用变量：{bot_name}、{target_name}、{target_pronoun}；留空则不发送查询等待提示；查询别人且使用默认模板时会自动显示 ta。"
                                                            },
                                  "reminder_text_template":  {
                                                                 "description":  "回群提醒提示模板",
                                                                 "type":  "string",
                                                                 "default":  "{target_name}，你不在的时候有 {count} 条艾特记录~",
                                                                 "hint":  "可用变量：{target_name}、{count}；留空则只发送提醒图片，不发送提示文字。"
                                                             }
                              }
                }
}
